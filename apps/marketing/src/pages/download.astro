---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Download — KarsaCode" description="Download KarsaCode for macOS, Windows, or Linux.">
  <div class="download-section">
    <div class="download-content">
      <h1 class="download-title">Get KarsaCode</h1>
      <p class="download-description">
        Contact your administrator to get access to KarsaCode for your team.
      </p>

      <div class="contact-card">
        <div class="contact-icon">📧</div>
        <h2 class="contact-title">Request Access</h2>
        <p class="contact-description">
          KarsaCode is distributed internally by Tool4File. Please contact your team administrator or the development team to get access.
        </p>
        <div class="contact-info">
          <div class="contact-item">
            <span class="contact-label">Company:</span>
            <span class="contact-value">Tool4File</span>
          </div>
          <div class="contact-item">
            <span class="contact-label">Developer:</span>
            <span class="contact-value">Quoriath</span>
          </div>
        </div>
      </div>

      <div class="info-section">
        <h2 class="info-title">System Requirements</h2>
        <div class="requirements-grid">
          <div class="requirement-item">
            <div class="requirement-icon">💻</div>
            <div class="requirement-content">
              <h3 class="requirement-title">Desktop App</h3>
              <p class="requirement-text">macOS, Windows, or Linux</p>
            </div>
          </div>
          <div class="requirement-item">
            <div class="requirement-icon">🤖</div>
            <div class="requirement-content">
              <h3 class="requirement-title">AI Providers</h3>
              <p class="requirement-text">Codex, Claude, or OpenCode</p>
            </div>
          </div>
          <div class="requirement-item">
            <div class="requirement-icon">🔧</div>
            <div class="requirement-content">
              <h3 class="requirement-title">Development</h3>
              <p class="requirement-text">Node.js, Bun, or Docker</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .main {
    padding: 0;
  }

  .download-section {
    min-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
  }

  .download-content {
    max-width: 800px;
    width: 100%;
  }

  .download-title {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    text-align: center;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #fff 0%, #a1a1aa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .download-description {
    font-size: 1.25rem;
    color: var(--fg-muted);
    text-align: center;
    margin-bottom: 3rem;
    line-height: 1.6;
  }

  .contact-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 3rem;
    margin-bottom: 3rem;
    backdrop-filter: blur(10px);
    text-align: center;
  }

  .contact-icon {
    font-size: 4rem;
    margin-bottom: 1.5rem;
  }

  .contact-title {
    font-size: 1.75rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: var(--fg);
  }

  .contact-description {
    color: var(--fg-muted);
    line-height: 1.6;
    margin-bottom: 2rem;
    font-size: 1.1rem;
  }

  .contact-info {
    display: flex;
    justify-content: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .contact-item {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-label {
    font-size: 0.875rem;
    color: var(--fg-dim);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contact-value {
    font-size: 1.125rem;
    font-weight: 500;
    color: var(--fg);
  }

  .info-section {
    margin-top: 4rem;
  }

  .info-title {
    font-size: 1.75rem;
    font-weight: 600;
    text-align: center;
    margin-bottom: 2rem;
    color: var(--fg);
  }

  .requirements-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
  }

  .requirement-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.3s ease;
  }

  .requirement-item:hover {
    border-color: rgba(99, 102, 241, 0.3);
    background: rgba(255, 255, 255, 0.04);
  }

  .requirement-icon {
    font-size: 2rem;
  }

  .requirement-content {
    flex: 1;
  }

  .requirement-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.25rem;
    color: var(--fg);
  }

  .requirement-text {
    font-size: 0.875rem;
    color: var(--fg-muted);
  }

  @media (max-width: 640px) {
    .download-section {
      padding: 3rem 1.5rem;
    }

    .contact-card {
      padding: 2rem;
    }

    .contact-info {
      gap: 2rem;
    }

    .requirements-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
