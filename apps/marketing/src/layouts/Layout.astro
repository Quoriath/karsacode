---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "KarsaCode",
  description = "KarsaCode — The best way to code with AI.",
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <div class="page">
      <nav class="nav">
        <a href="/" class="nav-brand">
          <img src="/icon.png" alt="KarsaCode" class="nav-icon" />
          <span class="nav-brand-text">KarsaCode</span>
        </a>
        <div class="nav-links">
          <a
            href="https://github.com/Quoriath/karsacode"
            target="_blank"
            rel="noopener noreferrer"
            class="nav-link"
          >
            GitHub
          </a>
        </div>
      </nav>

      <main class="main">
        <slot />
      </main>

      <footer class="footer">
        <div class="footer-content">
          <span class="footer-copy">&copy; {new Date().getFullYear()} Tool4File</span>
          <span class="footer-separator">•</span>
          <span class="footer-text">Built with ❤️ by Quoriath</span>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0a0a0b;
    --bg-gradient: linear-gradient(135deg, #0a0a0b 0%, #1a1a2e 50%, #0a0a0b 100%);
    --fg: #fafafa;
    --fg-muted: #a1a1aa;
    --fg-dim: #71717a;
    --border: rgba(255, 255, 255, 0.1);
    --accent: #6366f1;
    --accent-hover: #818cf8;
    --glass: rgba(255, 255, 255, 0.05);
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    color-scheme: dark;
  }

  body {
    background: var(--bg-gradient);
    color: var(--fg);
    font-family: "Inter", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at 50% 0%, rgba(99, 102, 241, 0.15) 0%, transparent 50%);
    z-index: -1;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  @keyframes fade-in {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes float {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
  }
</style>

<style>
  /* ── Page ── */

  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
  }

  /* ── Navbar ── */

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2.5rem;
    backdrop-filter: blur(10px);
    background: rgba(10, 10, 11, 0.8);
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .nav-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    transition: transform 0.3s ease;
  }

  .nav-brand:hover {
    transform: scale(1.02);
  }

  .nav-icon {
    width: 32px;
    height: 32px;
    border-radius: 8px;
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.3);
  }

  .nav-brand-text {
    font-weight: 600;
    font-size: 1.125rem;
    background: linear-gradient(135deg, #fff 0%, #a1a1aa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-link {
    color: var(--fg-muted);
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.3s ease, transform 0.2s ease;
    padding: 0.5rem 1rem;
    border-radius: 6px;
  }

  .nav-link:hover {
    color: var(--fg);
    background: var(--glass);
    transform: translateY(-1px);
  }

  /* ── Main content ── */

  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* ── Footer ── */

  .footer {
    display: flex;
    justify-content: center;
    padding: 2rem 2.5rem;
    font-size: 0.875rem;
    color: var(--fg-dim);
    border-top: 1px solid var(--border);
    background: rgba(10, 10, 11, 0.5);
    backdrop-filter: blur(10px);
  }

  .footer-content {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .footer-separator {
    color: var(--border);
  }

  .footer-text {
    color: var(--fg-muted);
  }

  /* ── Mobile ── */

  @media (max-width: 640px) {
    .nav {
      padding: 1rem 1.25rem;
    }

    .nav-brand-text {
      font-size: 1rem;
    }

    .footer {
      padding: 1.5rem 1.25rem;
      font-size: 0.8rem;
    }
  }
</style>
